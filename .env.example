# Plantilla de configuración de jira-gateway.
#
# Este fichero NO se carga desde aquí: cópialo a la ruta que carga
# gateway/config.py (por defecto ~/.secrets/jira-gateway.env, o la que
# indiques en JIRA_GATEWAY_ENV_FILE), fuera de este repo, y rellena los
# valores reales. No lo dejes con datos reales en el directorio del proyecto.

# --- Obligatorias ---

JIRA_EMAIL=tu-email@dominio.com
JIRA_API_TOKEN=el-token-con-scope-write:jira-work-y-read:jira-work
JIRA_CLOUD_ID=...           # GET https://tudominio.atlassian.net/_edge/tenant_info
JIRA_SITE_URL=https://tudominio.atlassian.net
JIRA_PROJECT_KEY=PROJ

# --- Opcionales (valor por defecto entre paréntesis) ---

# Estado de Jira que usa start_task cuando no se indica uno explícito.
JIRA_IN_PROGRESS_STATUS=In Progress

# Estado al que create_task mueve la tarea justo tras crearla.
JIRA_SELECTED_STATUS=Selected for Development

# Tipo de issue usado por create_task cuando no se pasa issue_type
# ni parent_key.
JIRA_DEFAULT_ISSUE_TYPE=Task

# Tipo de issue usado por create_task cuando se pasa parent_key sin
# issue_type explícito (para crear subtareas). Ajusta al nombre real
# de tu esquema si no es "Subtask" (p.ej. "Subtarea").
JIRA_SUBTASK_ISSUE_TYPE=Subtask

# --- Transporte MCP (no forman parte del "dominio" Jira, pero se pueden
# fijar en el mismo fichero de entorno si lo prefieres) ---

MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8765

# --- Nota ---
# JIRA_GATEWAY_ENV_FILE no va dentro de este fichero: es la variable que le
# dice a gateway/config.py DÓNDE está este fichero, así que se exporta en tu
# shell o en la config del proceso MCP, no aquí dentro.
